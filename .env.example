# Copy to .env and edit ATT_GAME_DIR (or leave the ./game default and let
# install.sh populate it). The tokens below are the offline, self-signed JWTs
# from the Windows install's startServer.bat (UserId 0, "Server", offline policy,
# expiry ~2058). They contact no Alta service.

# Path to your patched game folder. Default ./game = a folder inside this repo
# (git-ignored). install.sh can download it for you if you set GAME_URL below.
ATT_GAME_DIR=./game

# OPTIONAL: a URL to a .zip/.tar.gz of YOUR patched game folder that you host
# yourself (private release, S3, your own web server — NOT public GitHub). If set,
# install.sh downloads + extracts it into ./game. Leave blank to place files manually.
GAME_URL=

# Server instance id + game port (match startServer.bat: /start_server -1 false 1757)
INSTANCE_ID=-1
SERVER_PORT=1757

# --- Offline tokens (verbatim from startServer.bat) --------------------------
ATT_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..XZWt_WnrSG2ITJisUDV_im76MpjQ2xU5Prm0gMBZKjQ
ATT_REFRESH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJVc2VySWQiOiIwIiwicm9sZSI6IlJlZnJlc2giLCJleHAiOjI3OTE1NjQxMTMsImlzcyI6IkFsdGFXZWJBUEkiLCJhdWQiOiJBbHRhQ2xpZW50In0.Anle9q8ooVM080W30QY2mt2nAefPlDhkDaz-3VTfIug
ATT_IDENTITY_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJVc2VySWQiOiIwIiwiVXNlcm5hbWUiOiJTZXJ2ZXIiLCJyb2xlIjoiSWRlbnRpdHkiLCJleHAiOjI3OTE1NjQxMTMsImlzcyI6IkFsdGFXZWJBUEkiLCJhdWQiOiJBbHRhQ2xpZW50In0.1FleaoMleKDMb-fGP64C_825gVIIRdkPuWdy11E3xTk

# --- Server identity + community listing (v1.8.1 / TavernLib v1.3) -----------
# The entrypoint writes these into TavernLib's server_settings.json (in the Wine
# AppData, inside the wineprefix volume) at every boot. server-config.yaml is
# GONE in v1.8.1. See UPGRADE-1.8.1.md.

# The name friends see for your server. No quotes needed; spaces are fine.
# (v1.8.1 dropped the separate description field — the name is all there is now.)
SERVER_NAME=My Township Server

# Advertise on the community list? 1 = listed, 0 = unlisted (direct-IP only).
# Blank = auto: listed if LISTING_TOKEN is set (the old kit's behavior).
COMMUNITY_LISTED=1

# Your PRIVATE listing key — ANY long random string, UNIQUE to you. Not issued by
# anyone; it's just how the backend tracks (and lets you update) your listing.
# Leave blank and TavernLib generates one itself on first boot (install.sh may
# also fill one in). Do NOT share it and do NOT reuse a friend's.
LISTING_TOKEN=

# The address the listing advertises (new in v1.8.1 — the listing payload carries
# it, so IPv6-outbound VPSes no longer register the wrong address). Leave blank
# to auto-detect this box's public IPv4 at boot.
PUBLIC_HOSTNAME=

# Advertised player cap.
MAX_PLAYERS=8

# v1.8.1 server-side auth toggles (the server now runs a real auth service on
# TCP 1762 — friends' launcher registers a username + token there on first join;
# accounts persist in users.json inside the wineprefix volume).
#   WHITELIST_ENABLED=1  only whitelisted names/IPs may join
#   ENFORCE_IP_LIMIT=1   max 4 accounts per source IP
#   SERVER_PASSWORD_HASH set a join password by pasting a password_hash produced
#                        by the launcher's "set password" button (we don't hash).
WHITELIST_ENABLED=0
ENFORCE_IP_LIMIT=0
SERVER_PASSWORD_HASH=

# Community backend host. Leave as-is. Used by the optional curl -4 heartbeat
# fallback (register.sh); the native listing has it compiled in.
COMMUNITY_HOST=themoddingtavern.com

# Voice: v1.8.x ships CircuitLord's official voice chat inside your patched game
# folder — there is no server-side voice setting anymore. (The old self-hosted
# relay + VOICE_PORT/VOICE_RANGE are gone.)
